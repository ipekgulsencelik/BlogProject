
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<br />
<h2>İstatistikler</h2>

<div class="row">
    <div class="col-md-3">
        <!-- small box -->
        <div class="small-box bg-cyan">
            <div class="inner">
                <h3>@ViewBag.totalNumberOfCategories</h3>

                <p>Toplam Kategori Sayısı</p>
            </div>

            <div class="icon">
                <i class="ion ion-bag"></i>
            </div>

            <a href="#" class="small-box-footer"> <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-md-3">
        <!-- small box -->
        <div class="small-box bg-gray-dark">
            <div class="inner">
                <h3>@ViewBag.softwareCategoryTitleNumber<sup style="font-size: 20px"></sup></h3>

                <p>Yazılım Kategorisine Ait Başlık Sayısı</p>
            </div>

            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>

            <a href="#" class="small-box-footer"><i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-md-3">
        <!-- small box -->
        <div class="small-box bg-gradient-maroon">
            <div class="inner">
                <h3>@ViewBag.writerNameSortByA<sup style="font-size: 20px"></sup></h3>

                <p>Yazar Adında A harfi Geçen Yazar Sayısı</p>
            </div>

            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>

            <a href="#" class="small-box-footer"><i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-md-3">
        <!-- small box -->
        <div class="small-box bg-green">
            <div class="inner">
                <h3>@ViewBag.categoryNameWithTheMostTitles<sup style="font-size: 20px"></sup></h3>

                <p>En Fazla Başlığa Sahip Kategori Adı</p>
            </div>

            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>

            <a href="#" class="small-box-footer"><i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-md-3">
        <!-- small box -->
        <div class="small-box bg-gradient-purple">
            <div class="inner">
                <h3>@ViewBag.categoryStatus<sup style="font-size: 20px"></sup></h3>

                <p>Kategori Tablosunda Durumu True Olan Kategoriler ile False Olan Kategoriler Arasındaki Sayısal Fark</p>
            </div>

            <div class="icon">
                <i class="ion ion-stats-bars"></i>
            </div>

            <a href="#" class="small-box-footer"><i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>


